# Django backend environment.
# Copy to backend/.env and replace secrets before running.

DEBUG=False
SECRET_KEY=replace-with-django-secret-key

ALLOWED_HOSTS=example.com
CSRF_TRUSTED_ORIGINS=https://example.com
CORS_ALLOWED_ORIGINS=https://example.com

INTERNAL_API_TOKEN=replace-with-shared-worker-token

DB_NAME=algolab
DB_USER=algolab
DB_PASSWORD=replace-with-strong-db-password
DB_HOST=postgres
DB_PORT=5432

REDIS_PASSWORD=replace-with-strong-redis-password
REDIS_HOST=redis-cache
REDIS_PORT=6379
REDIS_DB=0

CELERY_REDIS_HOST=redis
CELERY_REDIS_PORT=6379
CELERY_REDIS_DB=0

GRADE_RESULT_REDIS_HOST=redis-result
GRADE_RESULT_REDIS_PORT=6379
GRADE_RESULT_REDIS_DB=0

REDIS_URL=
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
GRADE_RESULT_REDIS_URL=

SESSION_IDLE_TIMEOUT_SECONDS=5
SINGLE_SESSION_IDLE_TIMEOUT_MINUTES=60

OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_ADMIN_USERNAMES=
OAUTH_AUTHORIZE_URL=https://oauth.example.com/oauth/authorize/
OAUTH_TOKEN_URL=https://oauth.example.com/oauth/token/
OAUTH_PROFILE_URL=https://oauth.example.com/api/v1/account/profile/me/
OAUTH_CALLBACK_URL=https://example.com/oauth/complete/
OAUTH_REDIRECT_URI=https://example.com/dashboard

API_QUERY_METRICS_ENABLED=0
API_QUERY_METRICS_SLOW_MS=500
API_QUERY_METRICS_LOG_SQL=0
API_QUERY_METRICS_MAX_SQL=5
API_QUERY_METRICS_LOG_LEVEL=INFO
API_CACHE_ENABLED=1
API_CACHE_BOARD_LIST_TTL=20
API_CACHE_BOARD_DETAIL_TTL=20
API_CACHE_LIST_TTL=30
OAUTH_TOKEN_CACHE_TTL=900
OAUTH_TOKEN_TIMEOUT=0.6
